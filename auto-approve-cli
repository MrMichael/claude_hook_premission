#!/usr/bin/env python3
"""auto-approve-cli — PreToolUse hook client.

CC passes hook event as JSON on stdin. Client sends to daemon via Unix socket,
gets decision back, outputs CC hook response JSON on stdout.
"""
import json
import os
import socket
import subprocess
import sys
import time
from datetime import datetime, timezone

SOCKET_PATH = "/tmp/claude-auto-approve.sock"
TIMEOUT = 15

DAEMON_SCRIPT = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                              "auto_approve_daemon.py")


def build_request():
    """Read hook info from stdin, fall back to env vars."""
    try:
        stdin_data = sys.stdin.read()
        if stdin_data.strip():
            hook = json.loads(stdin_data)
            tool_name = hook.get("tool_name", "Unknown")
            tool_input = hook.get("tool_input", {})
            rationale = hook.get("permission_rationale",
                          tool_input.get("description", ""))
            command = tool_input.get("command",
                        tool_input.get("file_path",
                            tool_input.get("url", "")))
            return {
                "tool": tool_name,
                "command": str(command),
                "tool_input": tool_input,
                "rationale": rationale,
                "timestamp": datetime.now(timezone.utc).isoformat(),
            }
    except (json.JSONDecodeError, Exception):
        pass

    tool_name = os.environ.get("CLAUDE_TOOL_NAME", "Unknown")
    tool_input_str = os.environ.get("CLAUDE_TOOL_INPUT", "{}")
    rationale = os.environ.get("CLAUDE_PERMISSION_RATIONALE", "")
    try:
        tool_input = json.loads(tool_input_str)
    except json.JSONDecodeError:
        tool_input = {"raw": tool_input_str}
    command = tool_input.get("command",
                tool_input.get("file_path",
                    tool_input.get("url", "")))
    return {
        "tool": tool_name,
        "command": str(command),
        "tool_input": tool_input,
        "rationale": rationale,
        "timestamp": datetime.now(timezone.utc).isoformat(),
    }


def output_cc_response(decision, reason):
    """Output CC hook JSON on stdout."""
    resp = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
            "permissionDecisionReason": reason,
        }
    }
    print(json.dumps(resp))
    sys.exit(0)


def start_daemon():
    """Try to start the daemon. Returns True on success."""
    try:
        subprocess.run(
            [sys.executable, DAEMON_SCRIPT, "start"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            timeout=5,
        )
        time.sleep(0.5)
        return os.path.exists(SOCKET_PATH)
    except Exception:
        return False


def talk_to_daemon(request):
    """Connect to daemon, send request, return (decision, reason, should_notify)."""
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(TIMEOUT)
    sock.connect(SOCKET_PATH)
    sock.sendall((json.dumps(request) + "\n").encode("utf-8"))
    f = sock.makefile("r", buffering=1)
    line = f.readline()
    sock.close()
    if not line:
        raise ConnectionError("empty response")
    response = json.loads(line)
    return (response.get("decision", "deny"),
            response.get("reason", "unknown"),
            response.get("notify", False))


def notify_user(tool, cmd):
    """Desktop notification, best-effort."""
    if os.environ.get("DISPLAY"):
        try:
            subprocess.Popen(
                ["notify-send", "Claude Code Permission", f"{tool}: {cmd}",
                 "--expire-time=1000"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass


def main():
    request = build_request()

    if os.environ.get("AUTO_APPROVE_DRY_RUN"):
        print(json.dumps(request))
        sys.exit(0)

    decision = "deny"
    reason = "error"
    should_notify = False

    try:
        decision, reason, should_notify = talk_to_daemon(request)
    except (socket.timeout, ConnectionRefusedError, FileNotFoundError, ConnectionError):
        # Daemon not running — try to start it
        print("  auto-approve: starting daemon...", file=sys.stderr)
        if start_daemon():
            try:
                decision, reason, should_notify = talk_to_daemon(request)
            except Exception:
                print("  auto-approve: retry failed, allowing", file=sys.stderr)
                decision = "allow"
                reason = "daemon unreachable (fail-open)"
        else:
            print("  auto-approve: daemon start failed, allowing", file=sys.stderr)
            decision = "allow"
            reason = "daemon start failed (fail-open)"
    except json.JSONDecodeError:
        print("  auto-approve: bad response, allowing", file=sys.stderr)
        decision = "allow"
        reason = "bad daemon response (fail-open)"

    # Feedback
    tool = request["tool"]
    cmd = str(request.get("command", ""))[:60]
    print(f"  auto-approve [{decision}]: {tool} — {cmd} ({reason})", file=sys.stderr)

    if should_notify:
        notify_user(tool, cmd)

    output_cc_response(decision, reason)


if __name__ == "__main__":
    main()
