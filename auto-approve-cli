#!/usr/bin/env python3
"""auto-approve-cli — PreToolUse hook client.

CC passes hook event as JSON on stdin. Client sends to daemon via Unix socket,
gets decision back, outputs CC hook response JSON on stdout.
"""
import json
import os
import socket
import subprocess
import sys
from datetime import datetime, timezone

SOCKET_PATH = "/tmp/claude-auto-approve.sock"
TIMEOUT = 15


def build_request():
    """Read hook info from stdin, fall back to env vars."""
    try:
        stdin_data = sys.stdin.read()
        if stdin_data.strip():
            hook = json.loads(stdin_data)
            tool_name = hook.get("tool_name", "Unknown")
            tool_input = hook.get("tool_input", {})
            rationale = hook.get("permission_rationale",
                          tool_input.get("description", ""))
            command = tool_input.get("command",
                        tool_input.get("file_path",
                            tool_input.get("url", "")))
            return {
                "tool": tool_name,
                "command": str(command),
                "tool_input": tool_input,
                "rationale": rationale,
                "timestamp": datetime.now(timezone.utc).isoformat(),
            }
    except (json.JSONDecodeError, Exception):
        pass

    tool_name = os.environ.get("CLAUDE_TOOL_NAME", "Unknown")
    tool_input_str = os.environ.get("CLAUDE_TOOL_INPUT", "{}")
    rationale = os.environ.get("CLAUDE_PERMISSION_RATIONALE", "")
    try:
        tool_input = json.loads(tool_input_str)
    except json.JSONDecodeError:
        tool_input = {"raw": tool_input_str}
    command = tool_input.get("command",
                tool_input.get("file_path",
                    tool_input.get("url", "")))
    return {
        "tool": tool_name,
        "command": str(command),
        "tool_input": tool_input,
        "rationale": rationale,
        "timestamp": datetime.now(timezone.utc).isoformat(),
    }


def output_cc_response(decision, reason):
    """Output CC hook JSON on stdout — this is what CC reads."""
    resp = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
            "permissionDecisionReason": reason,
        }
    }
    print(json.dumps(resp))
    sys.exit(0)


def main():
    request = build_request()

    if os.environ.get("AUTO_APPROVE_DRY_RUN"):
        print(json.dumps(request))
        sys.exit(0)

    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(TIMEOUT)
        sock.connect(SOCKET_PATH)
        sock.sendall((json.dumps(request) + "\n").encode("utf-8"))

        f = sock.makefile("r", buffering=1)
        response_line = f.readline()
        if not response_line:
            output_cc_response("deny", "daemon not reachable")

        response = json.loads(response_line)
        decision = response.get("decision", "deny")
        reason = response.get("reason", "unknown")

        # User feedback on stderr (informational only)
        tool = request["tool"]
        cmd = str(request.get("command", ""))[:60]
        should_notify = response.get("notify", False)
        status = "allow" if decision == "allow" else "deny"

        # Desktop notification — only when daemon says notify
        if should_notify and os.environ.get("DISPLAY"):
            try:
                subprocess.Popen(
                    ["notify-send", "Claude Code Permission", f"{tool}: {cmd}",
                     "--expire-time=1000"],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                )
            except Exception:
                pass

        print(f"  auto-approve [{status}]: {tool} — {cmd} ({reason})", file=sys.stderr)
        output_cc_response(decision, reason)

    except (socket.timeout, ConnectionRefusedError, FileNotFoundError):
        print("  auto-approve: daemon not reachable", file=sys.stderr)
        output_cc_response("deny", "daemon not reachable")
    except json.JSONDecodeError:
        print("  auto-approve: bad response", file=sys.stderr)
        output_cc_response("deny", "invalid response from daemon")


if __name__ == "__main__":
    main()
